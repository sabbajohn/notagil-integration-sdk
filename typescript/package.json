{
  "name": "@notagil/integration-sdk",
  "version": "0.4.3",
  "description": "TypeScript SDK for the NotaAgil Integration API beta.",
  "type": "module",
  "license": "MIT",
  "author": "Sabba Sistemas",
  "homepage": "https://github.com/sabbajohn/notagil-integration-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabbajohn/notagil-integration-sdk.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/sabbajohn/notagil-integration-sdk/issues"
  },
  "keywords": [
    "notagil",
    "fiscal",
    "nfe",
    "nfce",
    "nfse",
    "sdk"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openapi-types": {
      "types": "./dist/openapi-types.d.ts",
      "import": "./dist/openapi-types.js"
    },
    "./openapi-types-v2": {
      "types": "./dist/openapi-types-v2.d.ts",
      "import": "./dist/openapi-types-v2.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:types": "npm run generate:types:v1 && npm run generate:types:v2",
    "generate:types:v1": "openapi-typescript ../openapi/integration-v1.yaml -o src/openapi-types.ts",
    "generate:types:v2": "openapi-typescript ../openapi/integration-v2.yaml -o src/openapi-types-v2.ts --default-non-nullable false",
    "test": "npm run build && node --test ./tests/smoke.test.mjs",
    "test:e2e": "npm run build && node ./tests/e2e-homolog.mjs",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.8.3"
  }
}
