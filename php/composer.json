{
  "name": "notagil/integration-sdk",
  "description": "PHP SDK for the NotaAgil public integration API.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "NotaAgil\\Integration\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NotaAgil\\Integration\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable"
}
